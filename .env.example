# =============================================================================
# SAT — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your API keys.
# SAT loads .env automatically — no need to export variables.
#
# At minimum, set ONE provider key (ANTHROPIC_API_KEY recommended).
# For cross-model adversarial critique, set keys for 2+ providers.
# For deep research, set PERPLEXITY_API_KEY or BRAVE_API_KEY.
# =============================================================================

# --- LLM Provider API Keys ---------------------------------------------------
# At least one is required. More keys = better adversarial critique.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- Default Models (optional) ------------------------------------------------
# Override the default model per provider. Omit to use built-in defaults.
# ANTHROPIC_MODEL=claude-opus-4-6
# OPENAI_MODEL=o3
# GEMINI_MODEL=gemini-2.5-pro

# --- Research Provider API Keys (optional) ------------------------------------
# Enable deep research (--research flag). Auto-selection priority:
# perplexity → brave → llm fallback
# PERPLEXITY_API_KEY=
# BRAVE_API_KEY=

# --- OpenAI Deep Research (optional) ------------------------------------------
# When OpenAI deep research hits a rate limit, fall back to this model.
# OPENAI_DEEP_RESEARCH_FALLBACK=gpt-4.1

# --- Gemini Deep Research (optional) -----------------------------------------
# Agent name for Gemini Interactions API. Separate from GEMINI_MODEL —
# the Interactions API expects an agent name, not a regular model identifier.
# GEMINI_DEEP_AGENT=deep-research-pro-preview-12-2025

# --- MCP Server (optional) ----------------------------------------------------
# Only needed when running the MCP server (sat-mcp).
# SAT_OUTPUT_DIR=.
# SAT_PRIMARY_PROVIDER=anthropic
# SAT_PRIMARY_MODEL=
# SAT_PRIMARY_API_KEY=
# SAT_ADVERSARIAL_ENABLED=false
# SAT_CHALLENGER_PROVIDER=anthropic
# SAT_CHALLENGER_MODEL=
# SAT_CHALLENGER_API_KEY=
