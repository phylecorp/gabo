{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./out/renderer",
    "rootDir": "./src/renderer",
    "baseUrl": "./src/renderer",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["src/renderer/**/*"]
}
